{
  "name": "ims",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @ims/web dev",
    "dev:server": "pnpm --filter @ims/server dev",
    "dev:desktop": "pnpm --filter @ims/desktop tauri dev",
    "build": "pnpm --filter @ims/shared build && pnpm --filter @ims/server build && pnpm --filter @ims/web build",
    "build:desktop": "pnpm build && pnpm --filter @ims/desktop tauri build",
    "build:desktop:local": "pnpm build && pnpm --filter @ims/desktop tauri build --config tauri.local.conf.json --no-sign",
    "build:server": "pnpm --filter @ims/server build",
    "build:web": "pnpm --filter @ims/web build",
    "typecheck": "pnpm --filter @ims/shared check && pnpm --filter @ims/server check && pnpm --filter @ims/web check",
    "check": "turbo run typecheck build --filter=!@ims/desktop",
    "clean": "turbo run clean && rm -rf node_modules packages/*/node_modules apps/*/node_modules",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:remote": "node ./scripts/playwright-remote.mjs",
    "reset:web": "bash ./scripts/reset-web-and-dev.sh",
    "reset:web-state": "bash ./scripts/reset-web-state.sh",
    "reset:web-state:open": "bash ./scripts/reset-web-state.sh --open",
    "reset:desktop-state": "bash ./scripts/reset-desktop-state.sh",
    "reset:desktop-full": "bash ./scripts/reset-desktop-state.sh --full",
    "desktop:reinstall": "bash ./scripts/reinstall-desktop.sh",
    "desktop:logs:open": "bash ./scripts/reset-desktop-state.sh --open-logs",
    "release:check": "node ./scripts/release-readiness.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "turbo": "^2.5.3",
    "typescript": "^5.9.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9"
}
