{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Interview Manager",
  "version": "0.1.0",
  "identifier": "com.company.interview-manager",
  "build": {
    "beforeDevCommand": "bun run dev:server",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "",
    "frontendDist": "../web/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Interview Manager",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
